@model IEnumerable<TaskModelView>

@{
    ViewData["Title"] = "Agile Board";
}

<head>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .board {
            min-index: 80vh;
        }

        .column {
            width: 300px;
            border-radius: 8px;
            padding: 10px;
            min-height: 500px;
        }

        .card {
            cursor: grab;
        }

            .card:active {
                cursor: grabbing;
            }
    </style>
</head>

<div class="container-fluid">
    <h2 class="text-center my-4">Agile Board</h2>

    <div class="mb-4 d-flex justify-content-center">
        <button type="button" class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#modalCrearTarea">
            <i class="bi bi-plus-circle"></i> Nueva Tarea
        </button>
    </div>

    <div class="modal fade" id="modalCrearTarea" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Crear Nueva Tarea</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @await Html.PartialAsync("_CreateFormPartial", new CasoI.PrograAvanzada.Models.TaskModelView())
                </div>
            </div>
        </div>
    </div>

    <div class="board d-flex justify-content-center gap-3">

        @await Html.PartialAsync("_Column",
        Model.Where(x => x.Estado == UserStoryStatus.Backlog).OrderBy(x => x.id),
                new ViewDataDictionary(ViewData) {
                { "ColumnName", "Backlog" },
                { "ColorClass", "bg-secondary" }
                })

        @await Html.PartialAsync("_Column",
                Model.Where(x => x.Estado == UserStoryStatus.ToDo).OrderBy(x => x.id),
                new ViewDataDictionary(ViewData) {
                { "ColumnName", "To Do" },
                { "ColorClass", "bg-primary" }
                })

        @await Html.PartialAsync("_Column",
                Model.Where(x => x.Estado == UserStoryStatus.InProgress).OrderBy(x => x.id),
                new ViewDataDictionary(ViewData) {
                { "ColumnName", "In Progress" },
                { "ColorClass", "bg-warning text-dark" }
                })

        @await Html.PartialAsync("_Column",
                Model.Where(x => x.Estado == UserStoryStatus.Done).OrderBy(x => x.id),
                new ViewDataDictionary(ViewData) {
                { "ColumnName", "Done" },
                { "ColorClass", "bg-success" },
                { "EfectoVisual", "shadow-lg border border-success" }
                })

    </div>
</div>

@section Scripts {
    <script src="~/js/javascript.js"></script>

    <script>
        @if (TempData["AltaDificultad"] != null)
        {
                <text>
                Swal.fire({
                    title: 'Notificación del Sistema',
            text: '@(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["AltaDificultad"]?.ToString()))',

                    icon: 'warning',
                    confirmButtonColor: '#ffc107',
                    confirmButtonText: 'Entendido'
                });
                </text>
        }

        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('createTaskForm');
            if (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    Swal.fire({
                        title: '¿Crear tarea?',
                        text: '¿Seguro de que deseas registrar esta nueva tarea?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, crear',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#198754',
                        cancelButtonColor: '#6c757d'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            }
        });
    </script>
}