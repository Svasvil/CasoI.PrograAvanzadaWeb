@model IEnumerable<TaskModelView>

@{
    ViewData["Title"] = "Agile Board";
}
<head>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</head>

<h2 class="text-center mb-4">Agile Board</h2>

<div class="mb-4 d-flex justify-content-center">
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCrearTarea">
        + Nueva Tarea
    </button>
</div>
<div class="modal fade" id="modalCrearTarea" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crear Nueva Tarea</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @await Html.PartialAsync("_CreateFormPartial", new CasoI.PrograAvanzada.Models.TaskModelView())
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('createTaskForm');
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            Swal.fire({
                title: '¿Crear nueva tarea?',
                text: '¿Estás seguro de que deseas crear esta tarea?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, crear',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
</script>

<div class="board d-flex justify-content-center gap-3">

    <div class="column">
        <div class="column-header @ViewData["ColorBacklog"]">Backlog</div>
        <div class="column-body">
            @foreach (var t in Model.Where(x => x.Estado == UserStoryStatus.Backlog).OrderBy(x => x.id))
            {
                <div class="card mb-2">
                    <div class="card-body p-2">
                        <strong>@t.Nombre</strong>
                        <p class="mb-1">@t.Descripcion</p>
                        <small class="text-muted">@t.AsignadoA</small><br />
                        <small>Estimación: @t.Dificultad</small>
                        <form method="post" asp-action="NextTask">
                            <input type="hidden" name="id" value="@t.id" />
                            <button type="submit" class="btn btn-primary btn-sm mt-1">Avanzar</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="column">
        <div class="column-header @ViewData["ColorToDo"]">To Do</div>
        <div class="column-body">
            @foreach (var t in Model.Where(x => x.Estado == UserStoryStatus.ToDo).OrderBy(x => x.id))
            {
                <div class="card mb-2">
                    <div class="card-body p-2">
                        <strong>@t.Nombre</strong>
                        <p class="mb-1">@t.Descripcion</p>
                        <small class="text-muted">@t.AsignadoA</small><br />
                        <small>Estimación: @t.Dificultad</small>
                        <form method="post" asp-action="NextTask">
                            <input type="hidden" name="id" value="@t.id" />
                            <button type="submit" class="btn btn-primary btn-sm mt-1">Avanzar</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="column">
        <div class="column-header @ViewData["ColorInProgress"]">In Progress</div>
        <div class="column-body">
            @foreach (var t in Model.Where(x => x.Estado == UserStoryStatus.InProgress).OrderBy(x => x.id))
            {
                <div class="card mb-2">
                    <div class="card-body p-2">
                        <strong>@t.Nombre</strong>
                        <p class="mb-1">@t.Descripcion</p>
                        <small class="text-muted">@t.AsignadoA</small><br />
                        <small>Estimación: @t.Dificultad</small>
                        <form method="post" asp-action="NextTask">
                            <input type="hidden" name="id" value="@t.id" />
                            <button type="submit" class="btn btn-warning btn-sm mt-1">Avanzar</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="column">
        <div class="column-header @ViewData["ColorDone"]">Done</div>
        <div class="column-body">
            @foreach (var t in Model.Where(x => x.Estado == UserStoryStatus.Done).OrderBy(x => x.id))
            {
                <div class="card mb-2">
                    <div class="card-body p-2">
                        <strong>@t.Nombre</strong>
                        <p class="mb-1">@t.Descripcion</p>
                        <small class="text-muted">@t.AsignadoA</small><br />
                        <small>Dificultad: @t.Dificultad</small>
                    </div>
                </div>
            }
        </div>
    </div>

</div>