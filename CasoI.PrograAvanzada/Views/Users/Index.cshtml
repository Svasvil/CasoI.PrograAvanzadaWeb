@model IEnumerable<CasoI.PrograAvanzada.Models.UsersModelView>



<head>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<h2 class="text-center mb-4">Gestión de Usuarios</h2>

<div class="mb-4 d-flex justify-content-center">
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrearUsuario">
        <i class="bi bi-person-plus-fill"></i> Nuevo Usuario
    </button>
</div>

<div class="modal fade" id="modalCrearUsuario" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalLabel">Registrar Nuevo Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @await Html.PartialAsync("_CreateUserPartial", new CasoI.PrograAvanzada.Models.UsersModelView())
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Avatar</th>
                        <th>Nombre Completo</th>
                        <th>Email</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/@(user.PokeApiAvatar).png"
                                     alt="Avatar"
                                     style="width: 60px; height: 60px;"
                                     class="img-thumbnail rounded-circle bg-light shadow-sm" />
                            </td>
                            <td>
                                <strong>@user.Nombre @user.Apellidos</strong>
                            </td>
                            <td>@user.email</td>
                            <td class="text-center">
                              <p>n/a</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>